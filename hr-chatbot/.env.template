# ============================================================================
# HR CHATBOT - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and update the values for your setup

# ============================================================================
# LM STUDIO CONFIGURATION
# ============================================================================
# Local LLM server address
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_MODEL=llama-3.2-3b-instruct
TEMPERATURE=0.3

# ============================================================================
# DOCUMENT CONFIGURATION
# ============================================================================
# Your HR Policy PDF file name (must be in the same folder as the scripts)
FILE_PATH=Egyptian_HR_Policy_Manual_Complete.pdf

# ============================================================================
# CHUNKING CONFIGURATION
# ============================================================================
CHUNK_SIZE=600
CHUNK_OVERLAP=100

# ============================================================================
# EMBEDDING CONFIGURATION
# ============================================================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================================================
# RETRIEVAL CONFIGURATION
# ============================================================================
SIMILARITY_K=10

# ============================================================================
# FLASK SERVER CONFIGURATION
# ============================================================================
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=False

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO
